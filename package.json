{
  "name": "@cuttledoc/monorepo",
  "description": "Fast offline video-to-document transcription with AI enhancement",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "docs:dev": "pnpm --filter @cuttledoc/docs run dev",
    "docs:build": "pnpm --filter @cuttledoc/docs run build",
    "format": "prettier --write .",
    "release": "pnpm --filter cuttledoc run release",
    "release:auto": "pnpm --filter cuttledoc run release:auto",
    "release:dry": "pnpm --filter cuttledoc run release:dry",
    "prepare": "husky"
  },
  "author": {
    "name": "Sebastian Werner",
    "email": "s.werner@sebastian-software.de",
    "url": "https://sebastian-software.de"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.5",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0"
  },
  "packageManager": "pnpm@10.34.5+sha512.a4ee05f2f73658255bd6a89859c065a45c28a57daefae2c893a168ee2b73168c37b91e83e57ea67654ad03f03031746430e8bce38e362e042605fb8abc80192e",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-llama-cpp"
    ]
  }
}
