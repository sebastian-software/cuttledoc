{
  "name": "@cuttledoc/monorepo",
  "description": "Fast offline video-to-document transcription with AI enhancement",
  "type": "module",
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "node scripts/check-pnpm-maturity-exclusions.mjs && node scripts/check-package-licenses.mjs && turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "docs:dev": "pnpm --filter @cuttledoc/docs run dev",
    "docs:build": "pnpm --filter @cuttledoc/docs run build",
    "format": "prettier --write .",
    "release": "pnpm --filter cuttledoc run release",
    "release:auto": "pnpm --filter cuttledoc run release:auto",
    "release:dry": "pnpm --filter cuttledoc run release:dry",
    "prepare": "husky"
  },
  "author": {
    "name": "Sebastian Werner",
    "email": "s.werner@sebastian-software.de",
    "url": "https://sebastian-software.de"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "24.10.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}
