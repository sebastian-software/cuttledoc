{
  "name": "cuttledoc",
  "version": "2.0.1",
  "description": "Fast offline video-to-document transcription with AI enhancement",
  "type": "module",
  "bin": {
    "cuttledoc": "./bin/cuttledoc.js"
  },
  "files": [
    "bin",
    "dist",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "benchmark": "npx tsx scripts/benchmark.ts",
    "benchmark:local": "npx tsx scripts/benchmark.ts --local",
    "benchmark:cloud": "npx tsx scripts/benchmark.ts --cloud",
    "fixtures:download": "python fixtures/download-samples.py"
  },
  "keywords": [
    "speech-recognition",
    "transcription",
    "whisper",
    "parakeet",
    "coreml",
    "apple-silicon",
    "macos",
    "offline"
  ],
  "author": {
    "name": "Sebastian Werner",
    "email": "s.werner@sebastian-software.de",
    "url": "https://sebastian-software.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sebastian-software/cuttledoc.git",
    "directory": "packages/cuttledoc"
  },
  "license": "MIT",
  "dependencies": {
    "@cuttledoc/ffmpeg": "workspace:*",
    "@cuttledoc/llm": "workspace:*",
    "parakeet-coreml": "^2.2.0",
    "whisper-coreml": "^1.1.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
