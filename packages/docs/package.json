{
  "name": "@cuttledoc/docs",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "pnpm run generate:seo && react-router build",
    "dev": "pnpm run generate:seo && react-router dev",
    "generate:seo": "node scripts/generate-seo-files.js",
    "start": "serve ./build/client",
    "test": "node --test scripts/*.test.js",
    "types:check": "react-router typegen && fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@react-router/node": "^8.2.0",
    "fumadocs-core": "16.11.5",
    "fumadocs-mdx": "15.2.0",
    "fumadocs-ui": "16.11.5",
    "isbot": "^5.2.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@react-router/dev": "^8.2.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.9.5",
    "release-it": "^20.2.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
