{
  "name": "@cuttledoc/docs",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "react-router build && node scripts/create-pages-fallback.js",
    "dev": "react-router dev",
    "preview": "vite preview",
    "start": "serve ./build/client",
    "test": "pnpm run build && node --test scripts/*.test.js",
    "types:check": "react-router typegen && tsc --noEmit",
    "typecheck": "pnpm run types:check",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "ardo": "4.2.0",
    "isbot": "^5.2.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@react-router/dev": "^8.2.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.9.5",
    "serve": "^14.2.6",
    "typescript": "^5.9.3",
    "vite": "^8.1.5"
  }
}
