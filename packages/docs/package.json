{
  "name": "@cuttledoc/docs",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "build": "pnpm run generate:seo && react-router build",
    "dev": "pnpm run generate:seo && react-router dev",
    "generate:seo": "node scripts/generate-seo-files.js",
    "start": "serve ./build/client",
    "test": "node --test scripts/*.test.js",
    "types:check": "react-router typegen && fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@react-router/node": "^7.18.1",
    "fumadocs-core": "16.11.5",
    "fumadocs-mdx": "14.3.2",
    "fumadocs-ui": "16.11.5",
    "isbot": "^5.2.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.1"
  },
  "devDependencies": {
    "@react-router/dev": "^7.18.1",
    "@release-it/conventional-changelog": "^10.0.6",
    "@tailwindcss/vite": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.9.5",
    "react-router-devtools": "^6.2.1",
    "release-it": "^19.2.4",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
