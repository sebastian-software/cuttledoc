{
  "name": "@cuttledoc/ffmpeg",
  "version": "1.0.0",
  "description": "Lightweight FFmpeg wrapper for audio processing",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "binary",
    "scripts/install.js"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "postinstall": "node scripts/install.js",
    "test": "node --test scripts/*.test.js && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "unzipper": "^0.12.5"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "ffmpeg",
    "audio",
    "transcription",
    "preprocessing"
  ],
  "license": "MIT",
  "author": {
    "name": "Sebastian Werner",
    "email": "s.werner@sebastian-software.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sebastian-software/cuttledoc",
    "directory": "packages/ffmpeg"
  }
}
